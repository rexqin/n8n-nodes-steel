{
  "name": "n8n-nodes-steel",
  "version": "0.1.0",
  "description": "n8n community node for Steel API",
  "license": "MIT",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo \"No linter configured\""
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
